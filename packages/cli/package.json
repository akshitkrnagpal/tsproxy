{
  "name": "@tsproxy/cli",
  "version": "0.1.0",
  "description": "CLI for tsproxy — Typesense search proxy framework",
  "type": "module",
  "bin": {
    "tsproxy": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node22",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
}
